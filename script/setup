#!/bin/bash
# Install all dotfiles into the home directory

set -eo pipefail

if [[ -L "$0" ]]; then
  SCRIPTSETUP="$(readlink "$0")"
else
  SCRIPTSETUP="$0"
fi

DOTFILESDIRREL="${SCRIPTSETUP%/*}"
[[ "${DOTFILESDIRREL}" = "${SCRIPTSETUP}" ]] && DOTFILESDIRREL="."
cd "${DOTFILESDIRREL}"/.. || exit
DOTFILESDIR=$(pwd -P)

UNAME_S="$(uname -s)"
[[ "${UNAME_S}" = "Darwin" ]] && export MACOS=1
[[ "${UNAME_S}" = "Linux" ]] && export LINUX=1
[[ "${UNAME_S}" == *_NT-* ]] && export WINDOWS=1
[[ -n "${LINUX}" ]] && grep -qEi "(Microsoft|WSL)" /proc/version && export WSL=1

# Detect dotfiles profile
DOTFILES_PROFILE_FILE="${HOME}/.dotfiles-profile"
if [[ -f "${DOTFILES_PROFILE_FILE}" ]]; then
  DOTFILES_PROFILE="$(cat "${DOTFILES_PROFILE_FILE}")"
elif [[ -n "${CI}" ]] || [[ -f "/.dockerenv" ]]; then
  DOTFILES_PROFILE="personal"
  echo "${DOTFILES_PROFILE}" >"${DOTFILES_PROFILE_FILE}"
elif [[ -t 0 ]]; then
  printf "Is this a personal or work machine? [personal/work]: "
  read -r DOTFILES_PROFILE
  echo "${DOTFILES_PROFILE}" >"${DOTFILES_PROFILE_FILE}"
else
  echo "Error: ${DOTFILES_PROFILE_FILE} not found. Run script/setup interactively to configure." >&2
  exit 1
fi

# Validate profile: check that a matching gitconfig exists (on macOS)
if [[ -n "${MACOS}" ]] && ! [[ -f "${DOTFILESDIR}/gitconfig.local.macos.${DOTFILES_PROFILE}" ]]; then
  echo "Error: No gitconfig.local.macos.${DOTFILES_PROFILE} found for profile '${DOTFILES_PROFILE}'." >&2
  exit 1
fi

if [[ -n "${MACOS}" ]]; then
  VSCODE="${HOME}/Library/Application Support/Code/User"
  CURSOR="${HOME}/Library/Application Support/Cursor/User"
elif [[ -n "${LINUX}" ]]; then
  VSCODE="${HOME}/.config/Code/User"
  CURSOR="${HOME}/.config/Cursor/User"
elif [[ -n "${WINDOWS}" ]]; then
  VSCODE="${APPDATA}/Code/User"
  CURSOR="${APPDATA}/Cursor/User"
  set -x
fi
ZED="${HOME}/.config/zed"
CCSTATUSLINE="${HOME}/.config/ccstatusline"

for DOTFILE in *; do
  HOMEFILE="${HOME}/.${DOTFILE}"
  if [[ -d "${DOTFILE}" ]]; then
    DOTFILE="${DOTFILE}/"
    IS_DIR=1
  else
    IS_DIR=
  fi
  DIRFILE="${DOTFILESDIR}/${DOTFILE}"

  # Don't mess with Codespaces' default SSH setup.
  if [[ -n "${CODESPACES}" && "${DOTFILE}" = "ssh/" ]]; then
    continue
  fi

  # Don't try to install some unneeded paths
  case "${DOTFILE}" in
    bin/|bundle/|script/|*.txt|*.md)
      continue
      ;;
  esac

  # Only install the profile-matching gitconfig.local.macos on macOS
  case "${DOTFILE}" in
    gitconfig.local.macos*)
      [[ -z "${MACOS}" ]] && continue
      [[ "${DOTFILE}" != "gitconfig.local.macos.${DOTFILES_PROFILE}" ]] && continue
      HOMEFILE="${HOME}/.gitconfig.local"
      ;;
    *vscode-settings*)
      HOMEFILE="${VSCODE}/settings.json"
      [[ -d "${VSCODE}" ]] || mkdir -p "${VSCODE}"
      ;;
    *cursor-settings*)
      HOMEFILE="${CURSOR}/settings.json"
      [[ -d "${CURSOR}" ]] || mkdir -p "${CURSOR}"
      ;;
    *vscode-keybindings*)
      HOMEFILE="${CURSOR}/keybindings.json"
      [[ -d "${CURSOR}" ]] || mkdir -p "${CURSOR}"
      ;;
    *zed-settings*)
      HOMEFILE="${ZED}/settings.json"
      [[ -d "${ZED}" ]] || mkdir -p "${ZED}"
      ;;
    *ccstatusline-settings*)
      HOMEFILE="${CCSTATUSLINE}/settings.json"
      [[ -d "${CCSTATUSLINE}" ]] || mkdir -p "${CCSTATUSLINE}"
      ;;
  esac

  # Don't install some files unless you're also called mpeteuil.
  if echo ${USER} | grep -vq 'mpeteuil'; then
    echo "${DOTFILE}" | grep -q 'gitconfig-user' && continue
    echo "${DOTFILE}" | grep -q 'ssh' && continue
  fi

  if [[ "${DOTFILE}" = *.sh ]]; then
    HOMEFILE="${HOME}/.${DOTFILE%.sh}"
  fi

  if [[ -z "${IS_DIR}" ]]; then
    [[ "${HOMEFILE}" -ef "${DIRFILE}" ]] && continue
    if [[ -L "${HOMEFILE}" ]]; then
      ln -sf "${DIRFILE}" "${HOMEFILE}"
    else
      ln -svf "${DIRFILE}" "${HOMEFILE}"
    fi
  elif [[ "${HOMEFILE}" -ef "${DIRFILE}" ]]; then
    continue
  elif [[ -L "${HOMEFILE}" ]]; then
    rm -r "${HOMEFILE}" 2>/dev/null
    ln -s "${DIRFILE}" "${HOMEFILE}"
  else
    rm -rfv "${HOMEFILE}" 2>/dev/null
    ln -sv "${DIRFILE}" "${HOMEFILE}"
  fi
done

HOMEDOTFILES="${HOME}/.dotfiles"
if ! [[ "${HOMEDOTFILES}" -ef "${DOTFILESDIR}" ]]; then
  rm -f "${HOMEDOTFILES}"
  ln -sf "${DOTFILESDIR}" "${HOMEDOTFILES}"
fi

AGENTS_GLOBAL="${DOTFILESDIR}/AGENTS-GLOBAL.md"
for HOMEFILE in "${HOME}/.claude/CLAUDE.md" "${HOME}/.codex/AGENTS.md"; do
  [[ -d "${HOMEFILE%/*}" ]] || mkdir -p "${HOMEFILE%/*}"
  if [[ "${HOMEFILE}" -ef "${AGENTS_GLOBAL}" ]]; then
    continue
  elif [[ -L "${HOMEFILE}" ]]; then
    ln -sf "${AGENTS_GLOBAL}" "${HOMEFILE}"
  else
    ln -svf "${AGENTS_GLOBAL}" "${HOMEFILE}"
  fi
done

# Setup my home directory how I like it
mkdir -pv ~/projects/Homebrew ~/projects/mpeteuil
if command -v "brew" >/dev/null && ! [[ -d ~/projects/Homebrew/brew ]]; then
  ln -vsf "$(brew --repository)" ~/projects/Homebrew/brew
fi
if ! [[ -d ~/projects/mpeteuil/dotfiles ]]; then
  ln -vsf "${DOTFILESDIR}" ~/projects/mpeteuil/dotfiles
fi

# Merge Claude Code statusLine setting into ~/.claude/settings.json
CLAUDE_SETTINGS="${HOME}/.claude/settings.json"
if command -v "jq" >/dev/null && [[ -f "${CLAUDE_SETTINGS}" ]]; then
  STATUSLINE_CONFIG='{"type":"command","command":"bunx --bun -y ccstatusline@latest","padding":0}'
  UPDATED=$(jq --argjson sl "${STATUSLINE_CONFIG}" '.statusLine = $sl' "${CLAUDE_SETTINGS}")
  echo "${UPDATED}" >"${CLAUDE_SETTINGS}"
fi

# Helper function to copy a file only when its contents change
sync_if_changed() {
  if ! [[ -f "${2}" ]] || ! cmp -s "${1}" "${2}"; then
    cp -vf "${1}" "${2}"
  fi
}

if command -v "brew" >/dev/null; then
  # Sync selected dotfiles into Sandvault guest home if that directory exists.
  SANDVAULT_GUEST_HOME="$(brew --prefix)/etc/sandvault/guest_home_user"
  if [[ -d "${SANDVAULT_GUEST_HOME}" ]]; then
    for i in shrc shprofile logout zprofile zshrc zlogout; do
      sync_if_changed "${DOTFILESDIR}/${i}.sh" "${SANDVAULT_GUEST_HOME}/.${i}"
    done

    for i in gitconfig gitignore; do
      sync_if_changed "${DOTFILESDIR}/${i}" "${SANDVAULT_GUEST_HOME}/.${i}"
    done

    [[ -d "${SANDVAULT_GUEST_HOME}/.bundle" ]] || mkdir -p "${SANDVAULT_GUEST_HOME}/.bundle"
    sync_if_changed "${DOTFILESDIR}/bundle/config" "${SANDVAULT_GUEST_HOME}/.bundle/config"

    [[ -d "${SANDVAULT_GUEST_HOME}/.claude" ]] || mkdir -p "${SANDVAULT_GUEST_HOME}/.claude"
    [[ -d "${SANDVAULT_GUEST_HOME}/.codex" ]] || mkdir -p "${SANDVAULT_GUEST_HOME}/.codex"
    for i in ".claude/CLAUDE.md" ".codex/AGENTS.md"; do
      sync_if_changed "${AGENTS_GLOBAL}" "${SANDVAULT_GUEST_HOME}/${i}"
    done
  fi
fi

if [[ -n "${LINUX}" ]]; then
  exec script/linux-after-setup
elif [[ -n "${CI}" && -n "${MACOS}" ]]; then
  exec script/strap-after-setup
fi
